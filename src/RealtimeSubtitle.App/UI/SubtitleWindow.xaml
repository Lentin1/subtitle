<Window x:Class="RealtimeSubtitle.App.UI.SubtitleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Realtime Subtitle"
        Width="960"
        Height="170"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen">
  <Border x:Name="Container"
          CornerRadius="8"
          Padding="22"
          Background="#AA000000"
          MouseLeftButtonDown="Container_OnMouseLeftButtonDown">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition Height="8" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <TextBlock x:Name="JapaneseText"
                 Grid.Row="0"
                 Text="等待开始"
                 FontSize="30"
                 Foreground="White"
                 TextAlignment="Center"
                 TextWrapping="Wrap"
                 VerticalAlignment="Center" />
      <TextBlock x:Name="ChineseText"
                 Grid.Row="2"
                 Text=""
                 FontSize="32"
                 Foreground="White"
                 TextAlignment="Center"
                 TextWrapping="Wrap"
                 VerticalAlignment="Center" />
    </Grid>
  </Border>
</Window>
