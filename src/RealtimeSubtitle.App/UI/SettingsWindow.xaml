<Window x:Class="RealtimeSubtitle.App.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="640"
        Height="720"
        WindowStartupLocation="CenterOwner">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="18">
      <TextBlock Text="音频" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
      <Grid Margin="0,0,0,16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,10,0">
          <TextBlock Text="采集模式" FontWeight="SemiBold" />
          <ComboBox x:Name="AudioModeBox" Margin="0,6,0,0">
            <ComboBoxItem Content="系统声音" Tag="device_loopback" />
            <ComboBoxItem Content="按应用监听" Tag="process_loopback" />
          </ComboBox>
        </StackPanel>
        <StackPanel Grid.Column="1">
          <TextBlock Text="目标进程" FontWeight="SemiBold" />
          <ComboBox x:Name="TargetAppBox" IsEditable="True" Margin="0,6,0,0" />
        </StackPanel>
      </Grid>

      <TextBlock Text="识别" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
      <Grid Margin="0,0,0,16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,10,0">
          <TextBlock Text="Whisper 模型" FontWeight="SemiBold" />
          <TextBox x:Name="ModelText" Margin="0,6,0,0" />
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="0,0,10,0">
          <TextBlock Text="设备" FontWeight="SemiBold" />
          <ComboBox x:Name="DeviceBox" Margin="0,6,0,0">
            <ComboBoxItem Content="cuda" />
            <ComboBoxItem Content="cpu" />
          </ComboBox>
        </StackPanel>
        <StackPanel Grid.Column="2">
          <TextBlock Text="计算类型" FontWeight="SemiBold" />
          <TextBox x:Name="ComputeTypeText" Margin="0,6,0,0" />
        </StackPanel>
      </Grid>

      <Grid Margin="0,0,0,16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,10,0">
          <TextBlock Text="最长片段秒数" FontWeight="SemiBold" />
          <TextBox x:Name="MaxSegmentText" Margin="0,6,0,0" />
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="0,0,10,0">
          <TextBlock Text="流式间隔秒数" FontWeight="SemiBold" />
          <TextBox x:Name="PartialIntervalText" Margin="0,6,0,0" />
        </StackPanel>
        <StackPanel Grid.Column="2">
          <TextBlock Text="停顿断句毫秒" FontWeight="SemiBold" />
          <TextBox x:Name="StableSilenceText" Margin="0,6,0,0" />
        </StackPanel>
      </Grid>

      <TextBlock Text="翻译" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
      <TextBlock Text="DeepSeek API Key" FontWeight="SemiBold" />
      <PasswordBox x:Name="ApiKeyBox" Margin="0,6,0,12" />
      <Grid Margin="0,0,0,16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,10,0">
          <TextBlock Text="上下文句数" FontWeight="SemiBold" />
          <TextBox x:Name="ContextText" Margin="0,6,0,0" />
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="0,0,10,0">
          <TextBlock Text="超时秒数" FontWeight="SemiBold" />
          <TextBox x:Name="TimeoutText" Margin="0,6,0,0" />
        </StackPanel>
        <StackPanel Grid.Column="2">
          <TextBlock Text="预览翻译字数" FontWeight="SemiBold" />
          <TextBox x:Name="PartialTranslateMinText" Margin="0,6,0,0" />
        </StackPanel>
      </Grid>
      <CheckBox x:Name="PartialTranslateCheck" Content="启用流式预览翻译" Margin="0,0,0,16" />

      <TextBlock Text="字幕" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
      <Grid Margin="0,0,0,16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,10,0">
          <TextBlock Text="日文字号" FontWeight="SemiBold" />
          <TextBox x:Name="JaSizeText" Margin="0,6,0,0" />
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="0,0,10,0">
          <TextBlock Text="中文字幕号" FontWeight="SemiBold" />
          <TextBox x:Name="ZhSizeText" Margin="0,6,0,0" />
        </StackPanel>
        <StackPanel Grid.Column="2">
          <TextBlock Text="自动隐藏秒数" FontWeight="SemiBold" />
          <TextBox x:Name="AutoHideText" Margin="0,6,0,0" />
        </StackPanel>
      </Grid>

      <Grid Margin="0,0,0,16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,10,0">
          <TextBlock Text="字体颜色" FontWeight="SemiBold" />
          <TextBox x:Name="FontColorText" Margin="0,6,0,0" />
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="0,0,10,0">
          <TextBlock Text="背景透明度" FontWeight="SemiBold" />
          <TextBox x:Name="OpacityText" Margin="0,6,0,0" />
        </StackPanel>
        <CheckBox x:Name="BackgroundCheck" Grid.Column="2" Content="启用背景" Margin="0,24,0,0" />
      </Grid>

      <TextBlock Text="快捷键" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
      <Grid Margin="0,0,0,16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <CheckBox x:Name="HotkeyCheck" Grid.Column="0" Content="启用开始/暂停热键" Margin="0,6,10,0" />
        <TextBox x:Name="HotkeyText" Grid.Column="1" Margin="0,0,0,0" />
      </Grid>

      <CheckBox x:Name="DebugLogCheck" Content="启用调试日志" Margin="0,0,0,18" />

      <TextBlock Text="按应用监听会自动刷新当前有音频会话的进程。真正的进程环回采集依赖 Windows 10 Build 20348+。"
                 TextWrapping="Wrap"
                 Foreground="#666666"
                 Margin="0,0,0,18" />

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="取消" Width="88" Margin="0,0,8,0" Click="Cancel_OnClick" />
        <Button Content="保存" Width="88" Click="Save_OnClick" />
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</Window>
