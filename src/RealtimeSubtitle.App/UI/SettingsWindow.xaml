<Window x:Class="RealtimeSubtitle.App.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="520"
        Height="560"
        WindowStartupLocation="CenterOwner">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="18">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <TextBlock Grid.Row="0" Text="Whisper 模型" FontWeight="SemiBold" />
      <TextBox x:Name="ModelText" Grid.Row="1" Margin="0,6,0,14" />

      <TextBlock Grid.Row="2" Text="DeepSeek API Key" FontWeight="SemiBold" />
      <PasswordBox x:Name="ApiKeyBox" Grid.Row="3" Margin="0,6,0,14" />

      <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,14">
        <StackPanel Width="150">
          <TextBlock Text="上下文句数" FontWeight="SemiBold" />
          <TextBox x:Name="ContextText" Margin="0,6,12,0" />
        </StackPanel>
        <StackPanel Width="150">
          <TextBlock Text="自动隐藏秒数" FontWeight="SemiBold" />
          <TextBox x:Name="AutoHideText" Margin="0,6,12,0" />
        </StackPanel>
        <StackPanel Width="150">
          <TextBlock Text="背景透明度" FontWeight="SemiBold" />
          <TextBox x:Name="OpacityText" Margin="0,6,0,0" />
        </StackPanel>
      </StackPanel>

      <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,0,14">
        <StackPanel Width="150">
          <TextBlock Text="日文字号" FontWeight="SemiBold" />
          <TextBox x:Name="JaSizeText" Margin="0,6,12,0" />
        </StackPanel>
        <StackPanel Width="150">
          <TextBlock Text="中文字幕号" FontWeight="SemiBold" />
          <TextBox x:Name="ZhSizeText" Margin="0,6,12,0" />
        </StackPanel>
        <StackPanel Width="150">
          <TextBlock Text="字体颜色" FontWeight="SemiBold" />
          <TextBox x:Name="FontColorText" Margin="0,6,0,0" />
        </StackPanel>
      </StackPanel>

      <CheckBox x:Name="DebugLogCheck" Grid.Row="6" Content="启用调试日志" Margin="0,0,0,14" />

      <TextBlock Grid.Row="7"
                 Text="MVP 使用默认输出设备 loopback 采集系统声音，Python worker 负责识别和翻译。"
                 TextWrapping="Wrap"
                 Foreground="#666666"
                 Margin="0,0,0,18" />

      <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="取消" Width="88" Margin="0,0,8,0" Click="Cancel_OnClick" />
        <Button Content="保存" Width="88" Click="Save_OnClick" />
      </StackPanel>
    </Grid>
  </ScrollViewer>
</Window>
